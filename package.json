{
  "name": "job-bot-app",
  "version": "0.5.8",
  "description": "Desktop app for automated job search and application",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --publish never",
    "dist:mac": "electron-builder --mac --publish never"
  },
  "dependencies": {
    "call-bind-apply-helpers": "^1.0.2",
    "docx": "^9.7.1",
    "electron-updater": "^6.8.9",
    "fingerprint-generator": "^2.1.82",
    "fingerprint-injector": "^2.1.82",
    "mammoth": "^1.12.0",
    "pdf-parse": "^1.1.4",
    "pdfkit": "^0.15.0",
    "playwright": "^1.48.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sql.js": "^1.13.0"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "25.1.8"
  },
  "build": {
    "appId": "com.femimerit.jobbotapp",
    "productName": "JobBot-AI",
    "publish": {
      "provider": "github",
      "owner": "seun888-del",
      "repo": "jobbot-app"
    },
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist",
      "!playwright-browsers",
      "!_tmp_*"
    ],
    "extraResources": [
      {
        "from": "playwright-browsers",
        "to": "playwright-browsers"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "${productName}-Setup-${version}.exe",
      "signAndEditExecutable": false
    },
    "afterPack": "./afterPack.js",
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.productivity",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "JobBot",
      "backgroundColor": "#ffffff",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "JobBot"
    }
  }
}
